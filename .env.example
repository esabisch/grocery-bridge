# Todoist personal API token: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# Project name in Todoist where Alexa drops items (case-sensitive match)
TODOIST_PROJECT_NAME=Groceries

# Walmart list name to push items into (must already exist in your account)
WALMART_LIST_NAME=Groceries

# Where Playwright stores its persistent browser profile (cookies, session)
# In Docker this maps to a mounted volume.
BROWSER_PROFILE_DIR=./data/browser_profile

# Where the SKU map JSON lives
SKU_MAP_PATH=./data/sku_map.json

# In production we trust this header from Cloudflare Access. Leave blank locally.
DEV_USER_EMAIL=esabisch@fni-stl.com

# Logging
LOG_LEVEL=INFO
